---
import "../styles/global.css";

const projects = [
	{
		name: "Webring Kit",
		description:
			"A framework-agnostic toolkit for GitHub-backed webrings, built around portable Web Components and plain JSON.",
		meta: "TypeScript · Web Components · OSS",
		href: "https://github.com/chtnnh/webring-kit",
		index: "01",
	},
	{
		name: "Blues",
		description:
			"A Redis-compatible subset written in async Python, with transactions, optimistic locking, replication, and property-based tests.",
		meta: "Python · Async IO · Distributed systems",
		href: "https://github.com/chtnnh/blues",
		index: "02",
	},
	{
		name: "Systems studies",
		description:
			"Small, deliberate implementations of a shell, load balancer, and scheduler to understand the machinery beneath abstractions.",
		meta: "Go · Networking · Operating systems",
		href: "https://github.com/chtnnh?tab=repositories",
		index: "03",
	},
];

const roles = [
	{
		period: "2025—now",
		role: "Senior Software Engineer",
		company: "CodeAnt AI",
		copy: "Building reliable AI systems for code security, and the infrastructure that keeps them useful at scale.",
	},
	{
		period: "2025",
		role: "Founding Engineer",
		company: "Unsiloed AI",
		copy: "Took multimodal models and workflow tooling from prototypes to production across cloud platforms.",
	},
	{
		period: "2024",
		role: "Independent Engineer",
		company: "Freelance",
		copy: "Shipped three zero-to-one products across TypeScript, Node, React, AWS, and Docker.",
	},
	{
		period: "2023",
		role: "Co-Founder",
		company: "42Peaks Inc.",
		copy: "Designed and built a specialized hospital management system for IVF and fertility clinics.",
	},
	{
		period: "2023",
		role: "Full Stack Software Engineer",
		company: "WisdomCircle",
		copy: "Owned product work across payments, search, PostgreSQL performance, and early AI-led sales tooling.",
	},
	{
		period: "2022",
		role: "Software Engineering Intern",
		company: "BharatX",
		copy: "Rebuilt credit-fraud prevention systems and accelerated a core matching process by over 100×.",
	},
	{
		period: "2021—2022",
		role: "Software Engineering Intern",
		company: "Questbook",
		copy: "Built products for decentralized grant management and large-scale technical learning.",
	},
	{
		period: "2020—2021",
		role: "Open Source Developer & Mentor",
		company: "Wikimedia Foundation",
		copy: "Built multilingual article-quality pipelines and mentored projects through GSoC and Outreachy.",
	},
];

const roleGroups = [roles.slice(0, 4), roles.slice(4)];

const title = "Chaitanya Mittal — Software Engineer & Poet";
const description =
	"Senior software engineer in Dubai building reliable AI and backend systems, open-source tools, and the occasional poem.";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f0eadb" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://me.chtnnhfoundation.org/" />
		<meta name="twitter:card" content="summary" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Manrope:wght@400;500;600&family=Newsreader:opsz,wght@6..72,400;6..72,500&family=Noto+Serif+Tamil:wght@500&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
		<script is:inline>
			const queryTheme = new URLSearchParams(location.search).get("theme");
			const savedTheme = localStorage.getItem("theme");
			const preferredTheme = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
			document.documentElement.dataset.theme =
				queryTheme === "light" || queryTheme === "dark" ? queryTheme : savedTheme || preferredTheme;
		</script>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			name: "Chaitanya Mittal",
			jobTitle: "Senior Software Engineer",
			worksFor: { "@type": "Organization", name: "CodeAnt AI" },
			address: { "@type": "PostalAddress", addressLocality: "Dubai" },
			url: "https://me.chtnnhfoundation.org",
			sameAs: [
				"https://github.com/chtnnh",
				"https://www.linkedin.com/in/chaitannah",
				"https://www.amazon.com/stores/Chaitanya-Mittal/author/B0DJFPHKM1",
			],
		})} />
	</head>
	<body>
		<a class="skip-link" href="#main">Skip to content</a>
		<header class="site-header shell">
			<a class="brand" href="#top" target="_blank" rel="noreferrer" aria-label="Chaitanya Mittal, home">
				<span class="monogram" lang="ta" aria-hidden="true">ச</span>
				<span class="brand-name">Chaitanya Mittal</span>
			</a>
			<nav aria-label="Primary navigation">
				<a href="#experience" target="_blank" rel="noreferrer">Experience</a>
				<a href="#work" target="_blank" rel="noreferrer">Projects</a>
				<a href="#writing" target="_blank" rel="noreferrer">Creative</a>
			</nav>
			<div class="header-actions">
				<a class="header-resume" href="/Chaitanya-Mittal-Resume.pdf" target="_blank" rel="noreferrer">
					<span class="header-resume__full">Résumé</span>
					<span class="header-resume__short">CV</span>
				</a>
				<button class="theme-toggle" type="button" aria-label="Switch color theme">
					<svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="4"></circle>
						<path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41"></path>
					</svg>
					<svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M20.2 15.1A8.5 8.5 0 0 1 8.9 3.8 8.5 8.5 0 1 0 20.2 15.1Z"></path>
					</svg>
					<span class="visually-hidden">Switch theme</span>
				</button>
			</div>
		</header>

		<main id="main">
			<section class="hero shell" id="top" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow reveal">Chaitanya Mittal · Senior Software Engineer · Dubai</p>
					<h1 id="hero-title" class="reveal">
						I build intelligent systems for people who <em>build <span>software.</span></em>
					</h1>
					<p class="hero-intro reveal">
						At <a href="https://www.codeant.ai/" target="_blank" rel="noreferrer">CodeAnt AI</a>, I work on reliable AI systems
						for code security. Elsewhere, I explore infrastructure, open source, and poetry.
					</p>
					<div class="hero-links reveal">
						<a class="text-link" href="#experience" target="_blank" rel="noreferrer">Explore experience <span>↘</span></a>
						<a class="text-link quiet" href="mailto:hello@chtnnhfoundation.org" target="_blank" rel="noreferrer">Say hello <span>↗</span></a>
					</div>
				</div>

				<div class="hero-visual" aria-hidden="true">
					<svg viewBox="0 0 620 590" role="presentation">
						<defs>
							<linearGradient id="sun" x1="0" x2="1" y1="0" y2="1">
								<stop offset="0" stop-color="var(--sun-start)" />
								<stop offset="1" stop-color="var(--sun-end)" />
							</linearGradient>
						</defs>
						<circle class="sun" cx="377" cy="205" r="146" fill="url(#sun)" />
						<g class="orbits">
							<circle cx="377" cy="205" r="185" />
							<path d="M137 473C215 391 272 338 377 205S513 82 576 50" />
							<path d="M78 539C145 475 211 434 305 421c85-12 166 7 236-34" />
							<path d="M377 205c-37 124-12 218 99 303" />
						</g>
						<g class="nodes">
							<circle cx="137" cy="473" r="7" />
							<circle cx="305" cy="421" r="7" />
							<circle cx="476" cy="508" r="7" />
							<circle cx="541" cy="387" r="7" />
							<circle cx="576" cy="50" r="7" />
						</g>
						<g class="plant">
							<path d="M91 557c48-67 84-127 99-216 10-60 2-114-12-160" />
							<path d="M188 360c-44-5-77-30-91-71 49-7 81 16 91 71Z" />
							<path d="M181 273c36-14 58-43 64-84-45 5-68 34-64 84Z" />
							<path d="M151 444c-41 2-72-17-94-56 45-14 80 4 94 56Z" />
							<path d="M125 499c27-7 51-1 72 21-30 15-55 8-72-21Z" />
						</g>
						<g class="coordinates">
							<text x="18" y="572">25.2048° N</text>
							<text x="18" y="588">55.2708° E</text>
							<text x="435" y="24">SYSTEM / GARDEN</text>
						</g>
					</svg>
				</div>
				<p class="hero-note mono">Designing for resilience, clarity, and useful surprise.</p>
			</section>

			<div class="field-notes" aria-hidden="true">
				<div class="field-notes__track">
					<span>AI SYSTEMS</span><i>✦</i><span>BACKEND INFRASTRUCTURE</span><i>✦</i>
					<span>OPEN SOURCE</span><i>✦</i><span>WORDS ON PAPER</span><i>✦</i>
					<span>AI SYSTEMS</span><i>✦</i><span>BACKEND INFRASTRUCTURE</span><i>✦</i>
					<span>OPEN SOURCE</span><i>✦</i><span>WORDS ON PAPER</span>
				</div>
			</div>

			<section class="section shell experience" id="experience" aria-labelledby="experience-title">
				<div class="section-heading reveal">
					<p class="section-number mono">02 / EXPERIENCE</p>
					<h2 id="experience-title">Backend-heavy.<br />Human-centred.</h2>
					<div class="section-aside">
						<p>
							I care about reliable platforms, legible architectures, and taking ambitious ideas
							all the way to production.
						</p>
						<a class="text-link" href="/Chaitanya-Mittal-Resume.pdf" target="_blank" rel="noreferrer">
							Read résumé <span>↗</span>
						</a>
					</div>
				</div>

				<div class="experience-viewport reveal">
					<div class="experience-track">
						{roleGroups.map((group, groupIndex) => (
							<div class="timeline" aria-label={`Experience group ${groupIndex + 1}`}>
								{group.map((role) => (
									<article class="role">
										<div class="role-heading">
											<div>
												<h3>{role.role}</h3>
												<p class="role-company">{role.company}</p>
											</div>
											<p class="role-period mono">{role.period}</p>
										</div>
										<p class="role-description">{role.copy}</p>
									</article>
								))}
							</div>
						))}
					</div>
				</div>
				<button class="experience-next" type="button" aria-label="Show older experience">
					<span class="experience-next__label">Earlier experience</span>
					<span class="experience-next__arrow" aria-hidden="true">→</span>
				</button>
			</section>

			<section class="section shell" id="work" aria-labelledby="work-title">
				<div class="section-heading reveal">
					<p class="section-number mono">03 / PROJECTS</p>
					<h2 id="work-title">Systems, experiments,<br />and open-source work.</h2>
					<p>Selected for the questions they explore, not the size of the repository.</p>
				</div>

				<div class="project-list">
					{projects.map((project) => (
						<a class="project reveal" href={project.href} target="_blank" rel="noreferrer">
							<span class="project-index mono">{project.index}</span>
							<div>
								<h3>{project.name}</h3>
								<p>{project.description}</p>
								<span class="project-meta mono">{project.meta}</span>
							</div>
							<span class="project-arrow" aria-hidden="true">↗</span>
						</a>
					))}
				</div>
			</section>

			<section class="section section--writing" id="writing" aria-labelledby="writing-title">
				<div class="shell writing-grid">
					<div class="section-heading reveal">
						<p class="section-number mono">04 / CREATIVE PRACTICE</p>
						<h2 id="writing-title">Words on paper.<br /><em>Music in motion.</em></h2>
						<p>
							A counterweight to systems work: poetry about the human condition, and mixes
							made mostly for the joy of it.
						</p>
					</div>
					<div class="creative-work">
						<a
							class="book reveal"
							href="https://www.amazon.com/stores/Chaitanya-Mittal/author/B0DJFPHKM1"
							target="_blank"
							rel="noreferrer"
						>
							<div class="book-cover">
								<img
									src="/images/3415-cover.jpg"
									alt="Cover of 3415: Volume 1, an ode to heartbreaks"
									width="313"
									height="500"
									loading="lazy"
								/>
							</div>
							<div class="book-info">
								<p class="mono">POETRY COLLECTION · VOLUME 1</p>
								<h3>3415: an ode to heartbreaks</h3>
								<p>A first collection tracing heartbreak through poems written across time.</p>
								<span class="text-link">View on Amazon <span>↗</span></span>
							</div>
						</a>

						<a
							class="music reveal"
							href="https://youtube.com/@chtnnh"
							target="_blank"
							rel="noreferrer"
						>
							<div class="music-visual" aria-hidden="true">
								<span></span><span></span><span></span><span></span><span></span>
								<span></span><span></span><span></span><span></span>
							</div>
							<div class="music-info">
								<p class="mono">MIXES · OCCASIONALLY LIVE</p>
								<h3>DJing, mostly for the joy of it.</h3>
								<p>
									Hobby mixes moving through ambient techno, DHH, Bollywood, and
									artist-led detours.
								</p>
								<span class="text-link">Listen on YouTube <span>↗</span></span>
							</div>
						</a>
					</div>
				</div>
			</section>
		</main>

		<footer>
			<section class="contact shell reveal" aria-labelledby="contact-title">
				<p class="section-number mono">05 / CONTACT</p>
				<h2 id="contact-title">Build something<br /><em>worth tending.</em></h2>
				<a class="contact-email" href="mailto:hello@chtnnhfoundation.org" target="_blank" rel="noreferrer">
					hello@chtnnhfoundation.org <span>↗</span>
				</a>
			</section>
			<div class="site-footer shell">
				<p>© {new Date().getFullYear()} Chaitanya Mittal</p>
				<div>
					<a href="https://github.com/chtnnh" target="_blank" rel="noreferrer">GitHub</a>
					<a href="https://www.linkedin.com/in/chaitannah" target="_blank" rel="noreferrer">LinkedIn</a>
					<a href="https://www.amazon.com/stores/Chaitanya-Mittal/author/B0DJFPHKM1" target="_blank" rel="noreferrer">Amazon</a>
					<a href="https://youtube.com/@chtnnh" target="_blank" rel="noreferrer">YouTube</a>
					<a href="/Chaitanya-Mittal-Resume.pdf" target="_blank" rel="noreferrer">Résumé</a>
				</div>
				<p class="mono">Dubai · UAE</p>
			</div>
		</footer>

		<script>
			const root = document.documentElement;
			const toggle = document.querySelector<HTMLButtonElement>(".theme-toggle");
			const themeColor = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');

			function setTheme(theme: "light" | "dark") {
				root.dataset.theme = theme;
				localStorage.setItem("theme", theme);
				themeColor?.setAttribute("content", theme === "dark" ? "#0d1c15" : "#f0eadb");
			}

			toggle?.addEventListener("click", () => {
				setTheme(root.dataset.theme === "dark" ? "light" : "dark");
			});

			const experience = document.querySelector<HTMLElement>(".experience");
			const experienceNext = document.querySelector<HTMLButtonElement>(".experience-next");
			const experienceLabel = document.querySelector<HTMLElement>(".experience-next__label");
			const experienceArrow = document.querySelector<HTMLElement>(".experience-next__arrow");

			experienceNext?.addEventListener("click", () => {
				const showingEarlier = experience?.classList.toggle("show-earlier") ?? false;
				experienceNext.setAttribute(
					"aria-label",
					showingEarlier ? "Show recent experience" : "Show older experience",
				);
				if (experienceLabel) {
					experienceLabel.textContent = showingEarlier ? "Recent experience" : "Earlier experience";
				}
				if (experienceArrow) {
					experienceArrow.textContent = showingEarlier ? "←" : "→";
				}
			});

			if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.12 },
				);
				document.querySelectorAll(".reveal").forEach((element) => observer.observe(element));
			} else {
				document.querySelectorAll(".reveal").forEach((element) => element.classList.add("is-visible"));
			}
		</script>
	</body>
</html>
